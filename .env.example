# ---------------------------------------------------------------------------
# KG Learning App — environment template. Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# --- Database (Prisma) ------------------------------------------------------
# Local dev uses SQLite (zero server). `npm run db:dev` does `prisma db push`.
DATABASE_URL="file:./dev.db"
# Production (Azure) uses PostgreSQL; CI flips the Prisma provider via db:deploy.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kglearn?sslmode=require"

# --- AI backend: Azure AI Foundry (BYOK) — MANDATORY in prod (PRD §4) -------
# The Copilot SDK is wired to Foundry via provider {type:"openai", baseUrl=.../openai/v1/}.
AZURE_AI_FOUNDRY_ENDPOINT="https://<your-foundry>.openai.azure.com"
AZURE_AI_FOUNDRY_API_KEY="<foundry-api-key>"
# Quality tier (lectures, assessment).
FOUNDRY_DEPLOYMENT_NAME="gpt-5"
# Fast/cost tier (high-volume research extraction). Falls back to quality if unset.
FOUNDRY_FAST_DEPLOYMENT_NAME="gpt-5-mini"

# --- Copilot SDK runtime ----------------------------------------------------
# Per-instance LOCAL temp only — never $HOME or a networked share (PRD §4.5).
COPILOT_HOME="/tmp/kglearn-copilot"

# --- Auth.js (NextAuth) -----------------------------------------------------
AUTH_SECRET="<generate-with: openssl rand -base64 32>"
# Optional Entra ID provider (default in prod):
# AUTH_MICROSOFT_ENTRA_ID_ID="<client-id>"
# AUTH_MICROSOFT_ENTRA_ID_SECRET="<client-secret>"
# AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant>/v2.0"

# --- Web search (research-engine) — OPTIONAL enrichment --------------------
# Research works out of the box on the Copilot SDK alone (the model expands the
# prerequisite graph from its own knowledge). Set a Tavily key ONLY if you also
# want live web-source citations; leaving it unset keeps research fully working.
# TAVILY_API_KEY="<tavily-api-key>"
# Optional: cap concurrent Foundry research sessions (users × parallelAgents).
# Defaults to 6 if unset.
# RESEARCH_MAX_CONCURRENT_SESSIONS="6"

# --- DEV-ONLY fallback: GitHub-hosted (NON-AZURE) models --------------------
# Used by the SDK only when NO Foundry provider is configured. NEVER set these
# in any deployed environment (prod throws if Foundry is absent). SDK priority:
# COPILOT_GITHUB_TOKEN > GH_TOKEN > GITHUB_TOKEN.
# COPILOT_GITHUB_TOKEN=""
# GH_TOKEN=""
# GITHUB_TOKEN=""
